---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign pages = site.pages | where_exp: "page", "page.url != '/404.html' and page.url != '/feed.xml' and page.url != '/robots.txt' and page.url != '/sitemap.xml'" %}
  {% for page in pages %}
  <url>
    <loc>{{ page.url | absolute_url | xml_escape }}</loc>
  </url>
  {% endfor %}
  {% for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}
</urlset>
